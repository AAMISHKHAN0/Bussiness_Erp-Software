# Frontend Environment Configuration
# Copy this file to .env and fill in your actual values

# API URL - where the backend is running
# For local development: http://localhost:5000/api
# For production: https://your-domain.com/api or /api (if same domain)
VITE_API_URL=http://localhost:5000/api

# Static resources URL (for uploads, images)
# Same as API URL but without /api path
VITE_RESOURCES_URL=http://localhost:5000

# Default tenant ID (for non-subdomain setups)
VITE_DEFAULT_TENANT=default
